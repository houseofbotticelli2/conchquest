# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (Railway injects DATABASE_URL automatically when you attach the
# Postgres plugin — copy it here for local dev). Must have PostGIS available;
# run `CREATE EXTENSION IF NOT EXISTS postgis;` once as a superuser if Railway
# doesn't enable it by default for your plan.
DATABASE_URL=postgres://user:password@localhost:5432/conchquest

# Supabase Auth
# Settings > API > Project URL
SUPABASE_URL=https://your-project.supabase.co
# Settings > API > JWT Settings > JWT Secret (used to verify access tokens server-side)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# OpenWeather (free tier: Current Weather + 5 day/3 hour forecast)
OPENWEATHER_API_KEY=your-openweather-api-key

# Environmental data caching
CONDITIONS_CACHE_TTL_MINUTES=20
NOAA_STATION_REFRESH_DAYS=30
